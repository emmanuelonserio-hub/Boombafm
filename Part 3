def pause_song():
    pygame.mixer.music.pause()
    print("Paused.")

def resume_song():
    pygame.mixer.music.unpause()
    print("Resumed.")

def stop_song():
    pygame.mixer.music.stop()
    print("Stopped.")

def main():
    while True:
        print("\n--- Boomba FM Player ---")
        print("1. List all songs")
        print("2. Play a song")
        print("3. Pause")
        print("4. Resume")
        print("5. Stop")
        print("6. Search songs")
        print("7. Exit")
